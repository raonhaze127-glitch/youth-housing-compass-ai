{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "purpose": "공공주택 공고의 우선 검토 순서를 결정하는 제품 규칙",
  "hard_gates": {
    "exclude_non_recruitment_notices": true,
    "exclude_likely_ineligible": true,
    "require_official_url": true,
    "require_housing_type": true,
    "allow_unknown_schedule": true,
    "unknown_schedule_label": "일정 확인 필요"
  },
  "ranking_signals": [
    {
      "id": "eligibility_fit",
      "weight": 40,
      "description": "Eligibility Agent의 항목별 조건 적합도"
    },
    {
      "id": "location_fit",
      "weight": 20,
      "description": "희망 지역 및 거주요건 적합도"
    },
    {
      "id": "target_group_fit",
      "weight": 15,
      "description": "청년·신혼부부 등 공급대상 적합도"
    },
    {
      "id": "application_status",
      "weight": 15,
      "description": "접수중, 모집예정, 일정 확인 필요, 마감 순"
    },
    {
      "id": "evidence_quality",
      "weight": 10,
      "description": "공고 원문과 구조화 근거의 완전성"
    }
  ],
  "status_order": [
    "open",
    "planned",
    "unknown",
    "closed"
  ],
  "eligibility_order": [
    "likely_eligible",
    "needs_review"
  ],
  "tie_breakers": [
    "apply_end_ascending",
    "evidence_quality_descending",
    "notice_date_descending"
  ],
  "required_explanations": [
    "recommendation_reason",
    "eligibility_summary",
    "uncertainties",
    "next_action",
    "official_url"
  ],
  "prohibited_outputs": [
    "guaranteed_eligibility",
    "guaranteed_winning",
    "invented_probability"
  ]
}
